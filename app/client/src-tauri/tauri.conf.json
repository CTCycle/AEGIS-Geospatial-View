{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AEGIS Desktop",
  "version": "1.7.0",
  "identifier": "com.aegis.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AEGIS Desktop",
        "url": "about:blank",
        "width": 1440,
        "height": 920,
        "center": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bundle-src/server": "r/server",
      "bundle-src/settings": "r/settings",
      "bundle-src/resources": "r/resources",
      "bundle-src/runtimes/python": "r/runtimes/python",
      "bundle-src/runtimes/uv": "r/runtimes/uv"
    }
  }
}
