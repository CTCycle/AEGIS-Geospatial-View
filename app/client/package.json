{
  "name": "aegis-client",
  "private": true,
  "version": "1.7.0",
  "scripts": {
    "start": "ng serve --proxy-config proxy.conf.cjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e:geospatial": "ng test --watch=false --browsers=ChromeHeadlessNoGpu --include src/app/e2e/geospatial-browser-smoke.spec.ts && node e2e/validate-geospatial-scenarios.cjs",
    "preview": "ng serve --proxy-config proxy.conf.cjs",
    "tauri:icon": "tauri icon public/favicon.png && powershell -NoProfile -Command \"Remove-Item -Recurse -Force ../src-tauri/icons/android,../src-tauri/icons/ios -ErrorAction SilentlyContinue\"",
    "tauri:dev": "tauri dev --config ../src-tauri/tauri.conf.json",
    "tauri:build": "tauri build --config ../src-tauri/tauri.conf.json",
    "tauri:export:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../release/tauri/scripts/export-windows-artifacts.ps1",
    "tauri:build:release": "npm run tauri:build && npm run tauri:export:windows",
    "tauri:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../release/tauri/scripts/clean-tauri-build.ps1"
  },
  "dependencies": {
    "@angular/animations": "^19.2.22",
    "@angular/common": "^19.2.22",
    "@angular/compiler": "^19.2.22",
    "@angular/core": "^19.2.22",
    "@angular/forms": "^19.2.22",
    "@angular/platform-browser": "^19.2.22",
    "@angular/platform-browser-dynamic": "^19.2.22",
    "@angular/router": "^19.2.22",
    "maplibre-gl": "^4.7.1",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.26",
    "@angular/cli": "^19.2.26",
    "@angular/compiler-cli": "^19.2.22",
    "@tauri-apps/cli": "^2.11.2",
    "@types/jasmine": "^5.1.0",
    "jasmine-core": "^5.6.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "typescript": "~5.7.2"
  }
}
