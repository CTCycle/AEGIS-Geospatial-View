###############################################################################
# Server Runtime
###############################################################################
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=7059
UI_HOST=127.0.0.1
UI_PORT=4512
RELOAD=false
OPTIONAL_DEPENDENCIES=true

###############################################################################
# Database Mode
###############################################################################
# true  = use the embedded SQLite database
# false = use the external PostgreSQL connection below
EMBEDDED_DATABASE=true

###############################################################################
# External Database Connection
###############################################################################
# When provided, DATABASE_URL seeds the host, port, database name, username,
# and password. Explicit DATABASE_* values below override URL parts.
DATABASE_URL=
DATABASE_ENGINE=postgresql+psycopg
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=AEGIS
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

###############################################################################
# External Database Security And Performance
###############################################################################
DATABASE_SSL=false
DATABASE_SSL_CA=
DATABASE_CONNECT_TIMEOUT=30
DATABASE_INSERT_BATCH_SIZE=1000


