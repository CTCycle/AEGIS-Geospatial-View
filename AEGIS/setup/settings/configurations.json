{
  "ollama_host_default": "http://localhost:11434",
  "http": {
    "timeout": 1800.0
  },
  "api": {
    "base_url": "http://127.0.0.1:8000"
  },
  "server": {
    "fastapi": {
      "title": "AEGIS Geospatial Search Backend",
      "description": "FastAPI backend",
      "version": "0.1.0"
    },
    "ui": {
      "host": "0.0.0.0",
      "port": 7861,
      "title": "AEGIS Geographics",
      "mount_path": "/ui",
      "redirect_path": "/ui",
      "show_welcome_message": false,
      "reconnect_timeout": 3600
    }
  },
  "database": {
    "selected_database": "sqlite",
    "database_address": null,
    "database_name": null,
    "username": null,
    "password": null,
    "insert_batch_size": 1000
  },
  "nominatim": {
    "base_url": "https://nominatim.openstreetmap.org/search",
    "user_agent": "AEGIS-Geographics/1.0 (contact: support@aegis-geographics.local)",
    "timeout": 10.0
  },
  "geospatial": {
    "min_timeline_year": 1900,
    "max_lat": 90.0,
    "min_lat": -90.0,
    "max_lon": 180.0,
    "min_lon": -180.0,
    "max_mercator_extent": 20037508.3427892
  },
  "maps": {
    "default_size_m": 500.0,
    "render_delay_s": 1.0,
    "tiles": "OpenStreetMap"
  },
    "gibs": {
      "user_agent": "AEGIS-GIBS/1.0",
      "timeout": 20.0,
      "capabilities_ttl_s": 21600.0,
      "max_cache_entries": 24,
      "bbox_precision": 6,
      "image_width": 1024,
      "image_height": 1024,
      "capabilities_endpoints": {
        "EPSG:4326": "https://gibs.earthdata.nasa.gov/wmts/epsg4326/best/1.0.0/WMTSCapabilities.xml",
        "EPSG:3857": "https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/1.0.0/WMTSCapabilities.xml",
        "EPSG:3413": "https://gibs.earthdata.nasa.gov/wmts/epsg3413/best/1.0.0/WMTSCapabilities.xml",
        "EPSG:3031": "https://gibs.earthdata.nasa.gov/wmts/epsg3031/best/1.0.0/WMTSCapabilities.xml"
      },
      "ows_namespaces": {
        "ows": "http://www.opengis.net/ows/1.1"
      },
      "layer_sync_user_agent": "AEGIS-GIBS-LayerSync/1.0",
      "layer_sync_timeout": 30.0,
      "nasa_attribution": "Imagery courtesy of NASA's Global Imagery Browse Services (GIBS), operated by the NASA/GSFC Earth Science Data and Information System (ESDIS) project.",
      "wms_base_endpoints": {
        "EPSG:3857": "https://gibs.earthdata.nasa.gov/wms/epsg3857/best/wms.cgi",
        "EPSG:4326": "https://gibs.earthdata.nasa.gov/wms/epsg4326/best/wms.cgi"
      },
    "retry_backoff_s": 2.0,
    "default_layer": "VIIRS_SNPP_CorrectedReflectance_TrueColor"
  },
  "client_runtime_defaults": {
    "agent_model": "llama3.1:8b",
    "llm_provider": "openai",
    "cloud_model": "gpt-4o-mini",
    "use_cloud_services": false,
    "ollama_temperature": 0.7,
    "ollama_reasoning": false
  }
}

